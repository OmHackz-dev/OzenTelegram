# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Default provider: apifreellm or cerebras
DEFAULT_PROVIDER=apifreellm

# APIFreeLLM
APIFREELLM_API_KEY=your_apifreellm_key
APIFREELLM_BASE_URL=https://api.apifreellm.com/v1
APIFREELLM_MODEL=gpt-4o-mini
APIFREELLM_COOLDOWN_SECONDS=25

# Cerebras
CEREBRAS_API_KEY=your_cerebras_key
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.1-8b

# Networking
REQUEST_TIMEOUT_SECONDS=30
